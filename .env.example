# Polymarket API Configuration
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control!

# =============================================================================
# CLOB API (clob.polymarket.com)
# =============================================================================

# Your Ethereum wallet private key (with 0x prefix)
# Used for L1 authentication and order signing
POLYMARKET_PRIVATE_KEY=0x

# Your wallet address (checksummed, with 0x prefix)
POLYMARKET_ADDRESS=0x

# API credentials (obtained via derive-api-key endpoint)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# Chain ID (137 for Polygon mainnet, 80001 for Mumbai testnet)
POLYMARKET_CHAIN_ID=137

# =============================================================================
# Builder Program (optional)
# =============================================================================

# Builder API credentials for order attribution
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=

# =============================================================================
# Polymarket US API (us-api.polymarket.com)
# =============================================================================

# Ed25519 credentials for US market access
POLYMARKET_US_API_KEY=
POLYMARKET_US_SECRET=
POLYMARKET_US_PASSPHRASE=

# =============================================================================
# Optional Settings
# =============================================================================

# Proxy wallet address (for Gnosis Safe users)
# POLYMARKET_PROXY_ADDRESS=0x

# API base URLs (defaults shown, override for testing)
# POLYMARKET_CLOB_URL=https://clob.polymarket.com
# POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
# POLYMARKET_DATA_URL=https://data-api.polymarket.com
# POLYMARKET_US_URL=https://us-api.polymarket.com

# Logging level (debug, info, warn, error)
# POLYMARKET_LOG_LEVEL=info
